{
  "name": "@kovito/kovitoboard",
  "version": "0.2.0",
  "description": "KovitoBoard - Self-extending AI agent team system on Claude Code",
  "license": "AGPL-3.0-or-later",
  "author": "Anode LLC",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"NODE_ENV=development tsx watch src/server/index.ts\" \"vite\"",
    "build": "vite build && tsc -b tsconfig.node.json --force && mkdir -p dist/server && cp src/server/trust-patterns.json dist/server/trust-patterns.json",
    "start": "node tools/kb-start.mjs",
    "start:detach": "node tools/kb-start.mjs --detach",
    "kb:stop": "node tools/kb-stop.mjs",
    "prod": "KOVITOBOARD_MODE=prod tsx src/server/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:l1": "playwright test -c playwright.config.l1.ts",
    "test:e2e:l2": "node tests/e2e/l2/run.mjs",
    "test:e2e:l2:all": "node tests/e2e/l2/run.mjs --all",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "check:hygiene": "node tools/check-release-hygiene.mjs",
    "diagnose": "node tools/kb-diagnose.mjs",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "chokidar": "^5.0.0",
    "dompurify": "^3.4.7",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "proper-lockfile": "^4.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.1",
    "rehype-highlight": "^7.0.2",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.0",
    "lefthook": "^2.1.6",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
